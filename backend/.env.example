# App
APP_NAME=DLens
FRONTEND_HOST=http://localhost:5173

# Local development auth bypass
AUTH_BYPASS=true
AUTH_BYPASS_USER_ID=1

# App/auth database used by SQLAlchemy models: users and user_tokens
SQLALCHEMY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fastapi_auth

# Pipeline destination database used by psycopg2 and Spark JDBC writes
DB_HOST=localhost
DB_PORT=5432
DB_NAME=dq_destination7
DB_USER=postgres
DB_PASSWORD=postgres

# MongoDB stores uploaded/source connection metadata
mongo_cred=mongodb://localhost:27017

# Relative paths are resolved from the backend folder
UPLOAD_DIRECTORY=uploaded_files/excel

# Email verification/reset. Mailpit or another local SMTP catcher can use port 1025.
MAIL_SERVER=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=your_email@example.com
MAIL_FROM_NAME=DLens
MAIL_STARTTLS=false
MAIL_SSL_TLS=false

# Runtime tools for local Spark processing on Windows
JAVA_HOME=C:\Program Files\Eclipse Adoptium\jdk-17.0.19.10-hotspot
HADOOP_HOME=
POSTGRES_JDBC_JAR=

# Replace these before enabling real auth outside local development.
JWT_SECRET=change-me
SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=14400
